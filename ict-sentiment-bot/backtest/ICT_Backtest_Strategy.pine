//@version=6
// ╔═══════════════════════════════════════════════════════════════════╗
// ║  ICT Sentinel — Backtest v5.0  (Pine Script v6)                  ║
// ║  Multi-Timeframe: D1/H4 bias → H1 structure → M15 entry         ║
// ║  Run on the M15 chart                                             ║
// ╠═══════════════════════════════════════════════════════════════════╣
// ║  ANTI-LOOKAHEAD GUARANTEES                                        ║
// ║  1. process_orders_on_close=false  fills at NEXT bar open        ║
// ║  2. calc_on_every_tick=false       confirmed bars only           ║
// ║  3. All HTF security calls use [1] + lookahead_off               ║
// ║  4. OB/FVG loops start at i=2  (never current bar)              ║
// ║  5. Sweep window checks past bars only (k=1 to sweep_window)     ║
// ╚═══════════════════════════════════════════════════════════════════╝
strategy(
    title                   = "ICT Sentinel — Backtest v5.0 (MTF)",
    overlay                 = true,
    process_orders_on_close = false,
    calc_on_every_tick      = false,
    initial_capital         = 50,
    currency                = currency.GBP,
    default_qty_type        = strategy.fixed,
    default_qty_value       = 0.01,
    commission_type         = strategy.commission.percent,
    commission_value        = 0.02,
    slippage                = 2,
    max_bars_back           = 500)

// ═══════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════

// Kill Zones
bool  use_london   = input.bool(true,  "London Kill Zone",              group="Kill Zones (UTC)")
int   london_start = input.int(7,      "London start (UTC)", minval=0, maxval=23, group="Kill Zones (UTC)")
int   london_end   = input.int(10,     "London end   (UTC)", minval=0, maxval=23, group="Kill Zones (UTC)")
bool  use_ny       = input.bool(true,  "New York Kill Zone",            group="Kill Zones (UTC)")
int   ny_start     = input.int(13,     "NY start (UTC)",     minval=0, maxval=23, group="Kill Zones (UTC)")
int   ny_end       = input.int(16,     "NY end   (UTC)",     minval=0, maxval=23, group="Kill Zones (UTC)")

// HTF Bias
float d1_rsi_long  = input.float(60.0, "D1 RSI >= X → SHORT (retail majority long)",  minval=51, maxval=90, group="HTF Bias (D1 + H4)")
float d1_rsi_short = input.float(40.0, "D1 RSI <= X → LONG  (retail majority short)", minval=10, maxval=49, group="HTF Bias (D1 + H4)")
int   h4_ema_len   = input.int(20,     "H4 EMA length", minval=5,                                           group="HTF Bias (D1 + H4)")
bool  require_h4   = input.bool(true,  "Require H4 trend to agree",
    tooltip="H4 EMA slope must match D1 bias direction. Uncheck to use D1 alone.",     group="HTF Bias (D1 + H4)")

// H1 Structure
int   h1_ob_lookback  = input.int(20,    "H1 OB lookback (bars)",  minval=5, maxval=50, group="H1 Structure (OB + FVG)")
float h1_ob_min_body  = input.float(5.0, "H1 OB min body (pips)",  minval=1.0,          group="H1 Structure (OB + FVG)")
int   h1_fvg_lookback = input.int(20,    "H1 FVG lookback (bars)", minval=5, maxval=50, group="H1 Structure (OB + FVG)")
float h1_fvg_min      = input.float(3.0, "H1 FVG min size (pips)", minval=0.5,          group="H1 Structure (OB + FVG)")

// M15 Entry Triggers
int sweep_window  = input.int(5, "Sweep lookback (M15 bars)",           minval=1, maxval=10, group="M15 Entry Triggers",
    tooltip="How many past bars to check for a liquidity sweep. 5 bars = 75 minutes.")
int m15_pivot_len = input.int(3, "M15 pivot strength (bars each side)", minval=2, maxval=10, group="M15 Entry Triggers")

// Risk and Exit
// Tiered: £50-£99 = £5/trade | £100-£199 = £10 | £200-£499 = £20 | £500+ = stay at £20
float sl_buffer_pips = input.float(5.0,  "SL buffer past invalidation (pips)", minval=2, maxval=20, group="Risk and Exit",
    tooltip="Breathing room below SSL (longs) or above BSL (shorts). Prevents 1-pip stop-outs.")
float fixed_sl_pips  = input.float(20.0, "Fallback SL if no level found (pips)", minval=10,          group="Risk and Exit")
bool  use_be         = input.bool(true,  "Move SL to breakeven at 1:1",                              group="Risk and Exit")
bool  use_partial    = input.bool(true,  "Close 30% at 2:1 R:R (let 70% run to full TP)",            group="Risk and Exit")
float full_rr        = input.float(4.0,  "Final TP R:R (on remaining 70%)", minval=2.0,              group="Risk and Exit")
bool  session_exit   = input.bool(true,  "Force close at kill zone end",
    tooltip="Closes all trades when the session ends. Keeps trades intraday as ICT intends.", group="Risk and Exit")
int   max_pos        = input.int(2, "Max open positions",  minval=1,           group="Risk and Exit")
int   max_wk_trades  = input.int(6, "Max trades per week", minval=1, maxval=20, group="Risk and Exit")

// ═══════════════════════════════════════════════════════════════════
// PIP SIZE  (auto-detected from pair)
// ═══════════════════════════════════════════════════════════════════
bool is_jpy = str.contains(syminfo.ticker, "JPY")
bool is_xau = str.contains(syminfo.ticker, "XAU") or str.contains(syminfo.ticker, "XAG")
bool is_gbp = str.contains(syminfo.ticker, "GBP")

float pip = 0.0
if is_jpy
    pip := syminfo.mintick * 100
else
    pip := syminfo.mintick * 10

// Approximate pip value per standard lot in GBP
float pip_val = 0.0
if is_gbp
    pip_val := 10.0
else if is_xau
    pip_val := 8.0
else if is_jpy
    pip_val := 7.5
else
    pip_val := 7.87

// ═══════════════════════════════════════════════════════════════════
// TIERED RISK SIZING  (fixed £ amounts, not % of equity)
// ═══════════════════════════════════════════════════════════════════
float balance = strategy.equity

float risk_amount = 0.0
if balance >= 200.0
    risk_amount := 20.0
else if balance >= 100.0
    risk_amount := 10.0
else
    risk_amount := 5.0

string risk_tier = ""
if balance >= 500.0
    risk_tier := "£20/trade  (re-evaluate)"
else if balance >= 200.0
    risk_tier := "£20 / trade"
else if balance >= 100.0
    risk_tier := "£10 / trade"
else
    risk_tier := "£5 / trade"

// Lot size = risk / (sl_pips * pip_val), rounded to 0.01, clamped 0.01–5.0
f_lots(float sl_pips) =>
    float raw  = risk_amount / math.max(sl_pips, 1.0) / pip_val
    float lots = math.round(raw / 0.01) * 0.01
    math.max(0.01, math.min(5.0, lots))

// ═══════════════════════════════════════════════════════════════════
// KILL ZONE
// ═══════════════════════════════════════════════════════════════════
int  utcH      = hour(time, "UTC")
bool in_london = use_london and utcH >= london_start and utcH < london_end
bool in_ny     = use_ny     and utcH >= ny_start     and utcH < ny_end
bool inKZ      = in_london or in_ny

bgcolor(in_london ? color.new(color.blue,   92) : na, title="London KZ")
bgcolor(in_ny     ? color.new(color.orange, 92) : na, title="NY KZ")

// ═══════════════════════════════════════════════════════════════════
// D1 CONTRARIAN SENTIMENT BIAS  (first filter — no extreme, no trade)
//
// myfxbook proxy: D1 RSI extreme = retail crowd at extreme positioning
//   RSI >= 60 → retail majority LONG  → institutions SHORT → we SHORT
//   RSI <= 40 → retail majority SHORT → institutions LONG  → we LONG
//   Between   → no clear extreme → skip
// ═══════════════════════════════════════════════════════════════════
float d1_rsi = request.security(syminfo.tickerid, "D", ta.rsi(close, 14)[1], lookahead=barmerge.lookahead_off)

int d1_bias = 0
if d1_rsi <= d1_rsi_short
    d1_bias := 1
else if d1_rsi >= d1_rsi_long
    d1_bias := -1

// ═══════════════════════════════════════════════════════════════════
// H4 TREND  (must agree with D1 bias when require_h4 is on)
// ═══════════════════════════════════════════════════════════════════
float h4_now  = request.security(syminfo.tickerid, "240", ta.ema(close, h4_ema_len)[1], lookahead=barmerge.lookahead_off)
float h4_prev = request.security(syminfo.tickerid, "240", ta.ema(close, h4_ema_len)[2], lookahead=barmerge.lookahead_off)
bool  h4_bull = h4_now > h4_prev
bool  h4_bear = h4_now < h4_prev

bool bias_long  = d1_bias ==  1 and (not require_h4 or h4_bull)
bool bias_short = d1_bias == -1 and (not require_h4 or h4_bear)

// ═══════════════════════════════════════════════════════════════════
// H1 ORDER BLOCKS
// ═══════════════════════════════════════════════════════════════════
float h1_o = request.security(syminfo.tickerid, "60", open[1],  lookahead=barmerge.lookahead_off)
float h1_c = request.security(syminfo.tickerid, "60", close[1], lookahead=barmerge.lookahead_off)

float h1_ob_top = math.max(h1_o, h1_c)
float h1_ob_bot = math.min(h1_o, h1_c)
bool  h1_ob_ok  = (h1_ob_top - h1_ob_bot) / pip >= h1_ob_min_body

// Bullish OB = last H1 bar was bearish (price displaced up from it)
bool in_h1_bull_ob = h1_ob_ok and h1_c < h1_o and close >= h1_ob_bot - 3*pip and close <= h1_ob_top + 3*pip
// Bearish OB = last H1 bar was bullish (price displaced down from it)
bool in_h1_bear_ob = h1_ob_ok and h1_c > h1_o and close >= h1_ob_bot - 3*pip and close <= h1_ob_top + 3*pip

// ═══════════════════════════════════════════════════════════════════
// H1 FAIR VALUE GAPS
// ═══════════════════════════════════════════════════════════════════
float h1_hi2 = request.security(syminfo.tickerid, "60", high[2], lookahead=barmerge.lookahead_off)
float h1_lo2 = request.security(syminfo.tickerid, "60", low[2],  lookahead=barmerge.lookahead_off)
float h1_hi1 = request.security(syminfo.tickerid, "60", high[1], lookahead=barmerge.lookahead_off)
float h1_lo1 = request.security(syminfo.tickerid, "60", low[1],  lookahead=barmerge.lookahead_off)

// Bullish FVG: gap between bar[2] high and bar[1] low
float h1_bull_fvg_bot = h1_hi2
float h1_bull_fvg_top = h1_lo1
bool  h1_bull_fvg_ok  = h1_lo1 > h1_hi2 and (h1_lo1 - h1_hi2) / pip >= h1_fvg_min
bool  in_h1_bull_fvg  = h1_bull_fvg_ok and close >= h1_bull_fvg_bot and close <= h1_bull_fvg_top

// Bearish FVG: gap between bar[2] low and bar[1] high
float h1_bear_fvg_top = h1_lo2
float h1_bear_fvg_bot = h1_hi1
bool  h1_bear_fvg_ok  = h1_lo2 > h1_hi1 and (h1_lo2 - h1_hi1) / pip >= h1_fvg_min
bool  in_h1_bear_fvg  = h1_bear_fvg_ok and close >= h1_bear_fvg_bot and close <= h1_bear_fvg_top

// ═══════════════════════════════════════════════════════════════════
// M15 LIQUIDITY LEVELS AND SWEEP DETECTION
// ═══════════════════════════════════════════════════════════════════
float ph = ta.pivothigh(high, m15_pivot_len, m15_pivot_len)
float pl = ta.pivotlow(low,   m15_pivot_len, m15_pivot_len)

var float bsl_level = na
var float ssl_level = na

if not na(ph)
    bsl_level := ph
if not na(pl)
    ssl_level := pl

bool bsl_swept = false
bool ssl_swept = false

if not na(bsl_level)
    for k = 1 to sweep_window
        if high[k] > bsl_level and close[k] < bsl_level
            bsl_swept := true
            break

if not na(ssl_level)
    for k = 1 to sweep_window
        if low[k] < ssl_level and close[k] > ssl_level
            ssl_swept := true
            break

plotshape(bsl_swept, "BSL Swept", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.small, offset=-1)
plotshape(ssl_swept, "SSL Swept", shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.small, offset=-1)

// ═══════════════════════════════════════════════════════════════════
// MARKET STRUCTURE SHIFT  (BOS / CHoCH)
//
// After a liquidity sweep, price must break through an internal
// swing level to confirm the institutional reversal:
//   SSL swept + close > internal swing HIGH = bullish BOS/CHoCH
//   BSL swept + close < internal swing LOW  = bearish BOS/CHoCH
//
// Uses a 2-bar internal pivot (tighter than the BSL/SSL pivots).
// ═══════════════════════════════════════════════════════════════════
float ms_ph = ta.pivothigh(high, 2, 2)
float ms_pl = ta.pivotlow(low,   2, 2)

var float ms_high = na
var float ms_low  = na

if not na(ms_ph)
    ms_high := ms_ph
if not na(ms_pl)
    ms_low := ms_pl

bool bos_bull = ssl_swept and not na(ms_high) and close > ms_high
bool bos_bear = bsl_swept and not na(ms_low)  and close < ms_low

plotshape(bos_bull, "BOS Bull", shape.labelup,   location.belowbar, color.new(color.teal,   20), size=size.tiny, text="BOS")
plotshape(bos_bear, "BOS Bear", shape.labeldown, location.abovebar, color.new(color.maroon, 20), size=size.tiny, text="BOS")

// ═══════════════════════════════════════════════════════════════════
// M15 ORDER BLOCKS  (backup when no H1 OB/FVG in range)
// ═══════════════════════════════════════════════════════════════════
bool  m15_bullOB = false
bool  m15_bearOB = false
float m15_bullOB_top = na
float m15_bullOB_bot = na
float m15_bearOB_top = na
float m15_bearOB_bot = na

if bar_index > h1_ob_lookback + 5
    for i = 2 to h1_ob_lookback
        float o_i  = open[i]
        float c_i  = close[i]
        float h_i  = high[i]
        float l_i  = low[i]
        float body = math.abs(c_i - o_i) / pip
        if body >= h1_ob_min_body
            if c_i < o_i and not m15_bullOB
                bool up_imp = false
                for j = 1 to math.min(i - 1, 5)
                    if high[i - j] > h_i
                        up_imp := true
                        break
                if up_imp and close >= c_i - 3*pip and close <= o_i + 3*pip
                    m15_bullOB     := true
                    m15_bullOB_top := o_i
                    m15_bullOB_bot := c_i
            if c_i > o_i and not m15_bearOB
                bool dn_imp = false
                for j = 1 to math.min(i - 1, 5)
                    if low[i - j] < l_i
                        dn_imp := true
                        break
                if dn_imp and close >= o_i - 3*pip and close <= c_i + 3*pip
                    m15_bearOB     := true
                    m15_bearOB_top := c_i
                    m15_bearOB_bot := o_i

// ═══════════════════════════════════════════════════════════════════
// M15 FAIR VALUE GAPS  (backup)
// ═══════════════════════════════════════════════════════════════════
bool  m15_bullFVG = false
bool  m15_bearFVG = false
float m15_bullFVG_top = na
float m15_bullFVG_bot = na
float m15_bearFVG_top = na
float m15_bearFVG_bot = na

if bar_index > h1_fvg_lookback + 5
    for i = 2 to h1_fvg_lookback
        float pH = high[i + 1]
        float pL = low[i + 1]
        float nH = high[i - 1]
        float nL = low[i - 1]
        if not m15_bullFVG and nL > pH
            float gap = (nL - pH) / pip
            if gap >= h1_fvg_min and close >= pH and close <= nL
                m15_bullFVG     := true
                m15_bullFVG_top := nL
                m15_bullFVG_bot := pH
        if not m15_bearFVG and nH < pL
            float gap = (pL - nH) / pip
            if gap >= h1_fvg_min and close >= nH and close <= pL
                m15_bearFVG     := true
                m15_bearFVG_top := pL
                m15_bearFVG_bot := nH

// ═══════════════════════════════════════════════════════════════════
// STRUCTURE CONFLUENCE  (H1 priority, M15 backup)
// ═══════════════════════════════════════════════════════════════════
bool structL = in_h1_bull_ob or in_h1_bull_fvg or m15_bullOB or m15_bullFVG
bool structS = in_h1_bear_ob or in_h1_bear_fvg or m15_bearOB or m15_bearFVG

// ═══════════════════════════════════════════════════════════════════
// WEEKLY TRADE CAP
// ═══════════════════════════════════════════════════════════════════
var int week_trades = 0
var int prev_closed = 0

if dayofweek(time) == 2 and dayofweek(time[1]) != 2
    week_trades := 0

int newly_closed = strategy.closedtrades - prev_closed
if newly_closed > 0
    week_trades += newly_closed
prev_closed := strategy.closedtrades

bool under_cap = (strategy.opentrades + week_trades) < max_wk_trades

// ═══════════════════════════════════════════════════════════════════
// ENTRY CONDITIONS — full ICT sequence (all five must align)
//   1. Contrarian sentiment (D1 RSI) + H4 trend  ← direction
//   2. Kill zone (London or NY)                   ← timing
//   3. Liquidity sweep (BSL or SSL)               ← institutional trigger
//   4. Market Structure Shift / BOS               ← confirms reversal
//   5. At OB or FVG zone                          ← precision entry
// ═══════════════════════════════════════════════════════════════════
bool canTrade  = strategy.opentrades < max_pos and under_cap
bool longCond  = canTrade and bias_long  and inKZ and ssl_swept and bos_bull and structL
bool shortCond = canTrade and bias_short and inKZ and bsl_swept and bos_bear and structS

// ═══════════════════════════════════════════════════════════════════
// STOP LOSS — placed at trade-invalidation level
//
// Long:  below the SSL sweep low  — if price returns below, sweep failed
// Short: above the BSL sweep high — if price returns above, sweep failed
// Falls back: zone edge → fixed pips. Floor = 15 pips.
// ═══════════════════════════════════════════════════════════════════
float sl_stop_long = na
if not na(ssl_level)
    sl_stop_long := ssl_level - sl_buffer_pips * pip
else if in_h1_bull_ob
    sl_stop_long := h1_ob_bot - sl_buffer_pips * pip
else if in_h1_bull_fvg
    sl_stop_long := h1_bull_fvg_bot - sl_buffer_pips * pip
else if m15_bullOB
    sl_stop_long := m15_bullOB_bot - sl_buffer_pips * pip
else if m15_bullFVG
    sl_stop_long := m15_bullFVG_bot - sl_buffer_pips * pip
else
    sl_stop_long := close - fixed_sl_pips * pip

float sl_stop_short = na
if not na(bsl_level)
    sl_stop_short := bsl_level + sl_buffer_pips * pip
else if in_h1_bear_ob
    sl_stop_short := h1_ob_top + sl_buffer_pips * pip
else if in_h1_bear_fvg
    sl_stop_short := h1_bear_fvg_top + sl_buffer_pips * pip
else if m15_bearOB
    sl_stop_short := m15_bearOB_top + sl_buffer_pips * pip
else if m15_bearFVG
    sl_stop_short := m15_bearFVG_top + sl_buffer_pips * pip
else
    sl_stop_short := close + fixed_sl_pips * pip

float sl_pips_long  = math.max(15.0, math.min(80.0, (close - sl_stop_long)  / pip))
float sl_pips_short = math.max(15.0, math.min(80.0, (sl_stop_short - close) / pip))

int sl_ticks_l   = math.round(sl_pips_long  * pip / syminfo.mintick)
int tp2r_ticks_l = math.round(sl_pips_long  * 2.0     * pip / syminfo.mintick)
int tp_ticks_l   = math.round(sl_pips_long  * full_rr * pip / syminfo.mintick)

int sl_ticks_s   = math.round(sl_pips_short * pip / syminfo.mintick)
int tp2r_ticks_s = math.round(sl_pips_short * 2.0     * pip / syminfo.mintick)
int tp_ticks_s   = math.round(sl_pips_short * full_rr * pip / syminfo.mintick)

// ═══════════════════════════════════════════════════════════════════
// ENTRIES AND EXITS
// ═══════════════════════════════════════════════════════════════════
if longCond
    strategy.entry("Long", strategy.long, qty=f_lots(sl_pips_long), comment="ICT L")
    if use_partial
        strategy.exit("Long 2R",   "Long", qty_percent=30, profit=tp2r_ticks_l, loss=sl_ticks_l)
        strategy.exit("Long Full", "Long", qty_percent=70, profit=tp_ticks_l,   loss=sl_ticks_l)
    else
        strategy.exit("Long Exit", "Long", profit=tp_ticks_l, loss=sl_ticks_l)

if shortCond
    strategy.entry("Short", strategy.short, qty=f_lots(sl_pips_short), comment="ICT S")
    if use_partial
        strategy.exit("Short 2R",   "Short", qty_percent=30, profit=tp2r_ticks_s, loss=sl_ticks_s)
        strategy.exit("Short Full", "Short", qty_percent=70, profit=tp_ticks_s,   loss=sl_ticks_s)
    else
        strategy.exit("Short Exit", "Short", profit=tp_ticks_s, loss=sl_ticks_s)

// ═══════════════════════════════════════════════════════════════════
// BREAKEVEN at 1:1
// ═══════════════════════════════════════════════════════════════════
var float entry_long  = na
var float entry_short = na
var bool  be_done_l   = false
var bool  be_done_s   = false

if longCond
    entry_long := close
    be_done_l  := false
if shortCond
    entry_short := close
    be_done_s   := false

if use_be
    if strategy.position_size > 0 and not be_done_l and not na(entry_long)
        if (close - entry_long) / pip >= sl_pips_long
            strategy.exit("Long BE", "Long", stop=entry_long + syminfo.mintick)
            be_done_l := true
    if strategy.position_size < 0 and not be_done_s and not na(entry_short)
        if (entry_short - close) / pip >= sl_pips_short
            strategy.exit("Short BE", "Short", stop=entry_short - syminfo.mintick)
            be_done_s := true

// ═══════════════════════════════════════════════════════════════════
// SESSION EXIT — force close when kill zone ends
// ═══════════════════════════════════════════════════════════════════
bool london_ended = use_london and utcH == london_end and hour(time[1], "UTC") == london_end - 1
bool ny_ended     = use_ny     and utcH == ny_end     and hour(time[1], "UTC") == ny_end - 1

if session_exit and (london_ended or ny_ended) and strategy.position_size != 0
    strategy.close_all(comment="Session End")

// ═══════════════════════════════════════════════════════════════════
// VISUALS — entry labels and zone boxes
// ═══════════════════════════════════════════════════════════════════
string long_zone = "M15 FVG"
if in_h1_bull_ob
    long_zone := "H1 OB"
else if in_h1_bull_fvg
    long_zone := "H1 FVG"
else if m15_bullOB
    long_zone := "M15 OB"

string short_zone = "M15 FVG"
if in_h1_bear_ob
    short_zone := "H1 OB"
else if in_h1_bear_fvg
    short_zone := "H1 FVG"
else if m15_bearOB
    short_zone := "M15 OB"

if longCond
    label.new(bar_index, low - 5*pip,
        "LONG  BOS\nSweep+KZ+" + long_zone + "\nSL " + str.tostring(math.round(sl_pips_long, 1)) + "p",
        color=color.new(color.teal, 15), textcolor=color.white,
        style=label.style_label_up, size=size.small)

if shortCond
    label.new(bar_index, high + 5*pip,
        "SHORT  BOS\nSweep+KZ+" + short_zone + "\nSL " + str.tostring(math.round(sl_pips_short, 1)) + "p",
        color=color.new(color.maroon, 15), textcolor=color.white,
        style=label.style_label_down, size=size.small)

plot(bsl_level, "BSL", color.new(color.red,   55), 1, plot.style_circles)
plot(ssl_level, "SSL", color.new(color.green, 55), 1, plot.style_circles)

var box h1_bull_box = na
var box h1_bear_box = na
if in_h1_bull_ob
    h1_bull_box := box.new(bar_index - 1, h1_ob_top, bar_index + 10, h1_ob_bot,
        border_color=color.new(color.teal,   40), bgcolor=color.new(color.teal,   85))
if in_h1_bear_ob
    h1_bear_box := box.new(bar_index - 1, h1_ob_top, bar_index + 10, h1_ob_bot,
        border_color=color.new(color.maroon, 40), bgcolor=color.new(color.maroon, 85))

// ═══════════════════════════════════════════════════════════════════
// INFO TABLE
// Uses barstate.islastconfirmedhistory (correct for calc_on_every_tick=false).
// All dynamic strings computed outside the table block to keep it clean.
// ═══════════════════════════════════════════════════════════════════
string sent_label = "No extreme — skip"
if d1_bias == 1
    sent_label := "Retail SHORT → we LONG"
else if d1_bias == -1
    sent_label := "Retail LONG  → we SHORT"
color sent_color = d1_bias != 0 ? color.lime : color.gray

string h4_label = "flat"
color  h4_color = color.gray
if h4_bull
    h4_label := "up"
    h4_color := color.lime
else if h4_bear
    h4_label := "dn"
    h4_color := color.red

string sweep_label = (ssl_swept ? "SSL " : "ssl ") + (bsl_swept ? "BSL" : "bsl")
string bos_label   = (bos_bull  ? "Bull " : "bull ") + (bos_bear ? "Bear" : "bear")
color  bos_color   = bos_bull or bos_bear ? color.lime : color.gray
string zone_label  = (structL ? "L " : "l ") + (structS ? "S" : "s")
string wk_label    = str.tostring(week_trades) + " / " + str.tostring(max_wk_trades)
color  wk_color    = week_trades >= max_wk_trades ? color.red : color.lime
color  tier_color  = balance >= 500.0 ? color.orange : color.lime
string bal_label   = "£" + str.tostring(math.round(balance, 2))

var table info = table.new(position.top_right, 2, 11,
    bgcolor=color.new(color.black, 75), border_width=1, frame_width=1)

if barstate.islastconfirmedhistory
    table.cell(info, 0, 0,  "ICT Sentinel v5",  text_color=color.white,  text_size=size.small)
    table.cell(info, 1, 0,  "MTF  M15 entry",   text_color=color.lime,   text_size=size.small)
    table.cell(info, 0, 1,  "1 Sentiment",       text_color=color.yellow, text_size=size.tiny)
    table.cell(info, 1, 1,  sent_label,          text_color=sent_color,   text_size=size.tiny)
    table.cell(info, 0, 2,  "D1 RSI",            text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 2,  str.tostring(math.round(d1_rsi, 1)), text_color=color.white, text_size=size.tiny)
    table.cell(info, 0, 3,  "H4 Trend",          text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 3,  h4_label,            text_color=h4_color,     text_size=size.tiny)
    table.cell(info, 0, 4,  "Kill Zone",         text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 4,  inKZ ? "ACTIVE" : "off", text_color=inKZ ? color.orange : color.gray, text_size=size.tiny)
    table.cell(info, 0, 5,  "Sweep",             text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 5,  sweep_label,         text_color=color.white,  text_size=size.tiny)
    table.cell(info, 0, 6,  "BOS / CHoCH",       text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 6,  bos_label,           text_color=bos_color,    text_size=size.tiny)
    table.cell(info, 0, 7,  "OB / FVG",          text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 7,  zone_label,          text_color=color.white,  text_size=size.tiny)
    table.cell(info, 0, 8,  "Wk trades",         text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 8,  wk_label,            text_color=wk_color,     text_size=size.tiny)
    table.cell(info, 0, 9,  "Risk tier",         text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 9,  risk_tier,           text_color=tier_color,   text_size=size.tiny)
    table.cell(info, 0, 10, "Balance",           text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 10, bal_label,           text_color=color.white,  text_size=size.tiny)
