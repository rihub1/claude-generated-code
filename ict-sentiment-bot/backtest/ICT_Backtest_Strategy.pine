// ╔══════════════════════════════════════════════════════════════════╗
// ║    ICT Sentinel — Backtest v3.0  (Pine Script v6)               ║
// ║    Multi-Timeframe: D1/H4 bias  →  H1 structure  →  M15 entry  ║
// ║    Run this script on the M15 chart                              ║
// ╠══════════════════════════════════════════════════════════════════╣
// ║  ANTI-LOOKAHEAD GUARANTEES                                       ║
// ║  1. process_orders_on_close=false → fills at NEXT bar open      ║
// ║  2. calc_on_every_tick=false      → confirmed (closed) bars only ║
// ║  3. All HTF data uses [1] + lookahead_off → previous HTF bar    ║
// ║  4. OB/FVG loops scan backwards from i=2 — all past history     ║
// ║  5. Sweep window: last 5 M15 bars (≈75 mins) — all confirmed    ║
// ╚══════════════════════════════════════════════════════════════════╝

//@version=6
strategy(
     title                   = "ICT Sentinel — Backtest v4.0 (MTF)",
     overlay                 = true,
     process_orders_on_close = false,
     calc_on_every_tick      = false,
     initial_capital         = 50,
     currency                = currency.USD,
     default_qty_type        = strategy.fixed,    // we calculate lot size manually
     default_qty_value       = 0.01,              // fallback minimum (overridden per trade)
     commission_type         = strategy.commission.percent,
     commission_value        = 0.02,
     slippage                = 2,
     max_bars_back           = 500
     )

// ─────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────

// Kill Zones
bool  use_london    = input.bool (true,  "London Kill Zone",              group="Kill Zones (UTC)")
int   london_start  = input.int  (7,     "London start (UTC)",  minval=0, maxval=23, group="Kill Zones (UTC)")
int   london_end    = input.int  (10,    "London end   (UTC)",  minval=0, maxval=23, group="Kill Zones (UTC)")
bool  use_ny        = input.bool (true,  "New York Kill Zone",            group="Kill Zones (UTC)")
int   ny_start      = input.int  (13,    "NY start (UTC)",      minval=0, maxval=23, group="Kill Zones (UTC)")
int   ny_end        = input.int  (16,    "NY end   (UTC)",      minval=0, maxval=23, group="Kill Zones (UTC)")

// HTF Bias — myfxbook sentiment (live EA reads this from CSV)
// In backtest we cannot pull live myfxbook data so set manually:
//   "Longs only"  = myfxbook shows retail majority SHORT → we go LONG
//   "Shorts only" = myfxbook shows retail majority LONG  → we go SHORT
//   "Both"        = no sentiment filter, take all ICT setups
string sentiment_bias = input.string("Both", "Myfxbook sentiment bias",
                        options=["Longs only", "Shorts only", "Both"],
                        group="HTF Bias  (D1 + H4)",
                        tooltip="Live EA: auto-reads myfxbook CSV.\nBacktest: set manually based on sentiment at the time you are testing.")
int   h4_ema_len    = input.int  (20,    "H4 EMA length (trend confirm)", minval=5,  group="HTF Bias  (D1 + H4)",
                        tooltip="H4 EMA slope confirms direction. Filters trades against short-term momentum.")
bool  require_h4    = input.bool (true,  "Require H4 trend to agree",                group="HTF Bias  (D1 + H4)",
                        tooltip="H4 EMA must slope in same direction as sentiment bias.")

// H1 Structure (Order Blocks & FVGs identified on H1)
int   h1_ob_lookback = input.int (20,   "H1 OB lookback (bars)",  minval=5, maxval=50,  group="H1 Structure  (OB + FVG)")
float h1_ob_min_body = input.float(5.0, "H1 OB min body (pips)",  minval=1.0,           group="H1 Structure  (OB + FVG)")
int   h1_fvg_lookback= input.int (20,   "H1 FVG lookback (bars)", minval=5, maxval=50,  group="H1 Structure  (OB + FVG)")
float h1_fvg_min     = input.float(3.0, "H1 FVG min size (pips)", minval=0.5,           group="H1 Structure  (OB + FVG)")

// M15 Entry Triggers
bool  require_bos    = input.bool (false, "Require BOS/CHoCH before entry (strict ICT flow)",  group="M15 Entry Triggers",
                        tooltip="ON = full sequential ICT flow: BOS in kill zone → retrace to zone → entry.\nOFF = simpler: bias + kill zone + in zone = entry. Use OFF first to validate zones.")
bool  require_zone   = input.bool (false, "Require OB/FVG zone confirmation",                   group="M15 Entry Triggers",
                        tooltip="ON = price must be inside a D1/H4/H1/M15 OB or FVG to enter.\nOFF = bias + kill zone alone triggers entry. Turn OFF to verify bias/KZ logic works.")
int   m15_pivot_len  = input.int (3,    "M15 swing strength (bars each side)", minval=2, maxval=10, group="M15 Entry Triggers")
int   sweep_window    = input.int (5,    "Sweep lookback window (M15 bars)",    minval=1, maxval=10, group="M15 Entry Triggers",
                        tooltip="How many past M15 bars to check for a liquidity sweep.\n5 bars = look back 75 minutes for a sweep.")
int   bos_expire_bars = input.int (48,   "BOS valid window (M15 bars after BOS)",minval=4, maxval=192, group="M15 Entry Triggers",
                        tooltip="How many M15 bars after a BOS to still look for a retrace entry.\n48 bars = 12 hours. After this window the pending setup expires.")

// Risk & Exit — tiered fixed-amount sizing
// £50–£99 = £5/trade  |  £100–£199 = £10/trade  |  £200–£499 = £20/trade  |  £500+ = hold at £20
float sl_buffer_pips = input.float(10.0, "SL buffer beyond invalidation (pips)", minval=2, maxval=50, group="Risk and Exit",
                        tooltip="Extra pips beyond the sweep level or zone edge.\nFor XAUUSD: 10 pips = $10. For FX majors: 10 pips = 0.001.")
float fixed_sl_pips  = input.float(30.0, "Fallback SL (pips, if no sweep level)", minval=10,             group="Risk and Exit",
                        tooltip="XAUUSD: 30 pips = $30 fallback stop. Increase if getting stopped by noise.")
bool  use_be         = input.bool (true,  "Move SL to breakeven at 1:1",                            group="Risk and Exit")
bool  use_partial    = input.bool (true,  "Close 50% at 2:1 R:R",                                   group="Risk and Exit")
float full_rr        = input.float(4.0,  "Final TP (R:R on remaining 70%)",  minval=2.0,            group="Risk and Exit")
bool  session_exit   = input.bool (true,  "Close before weekend (Friday)",                          group="Risk and Exit",
                        tooltip="Closes any open trade on Friday at 20:00 UTC to avoid weekend gap risk.\nTrades can otherwise run through the week until TP/SL is hit.")
int   max_pos        = input.int  (2,    "Max open positions",                minval=1,              group="Risk and Exit")
int   max_wk_trades  = input.int  (6,    "Max trades per week",               minval=1, maxval=20,   group="Risk and Exit")

// ─────────────────────────────────────────────────────────────────────
// PIP SIZE  (auto-detects pair)
// ─────────────────────────────────────────────────────────────────────
// XAU/XAG: mintick=0.01, 1 pip = $1.00 → multiply by 100
// JPY pairs: mintick=0.001, 1 pip = 0.01 → multiply by 10
// FX majors: mintick=0.00001, 1 pip = 0.0001 → multiply by 10
float pip = syminfo.mintick *
     (str.contains(syminfo.ticker, "XAU") ? 100 :
      str.contains(syminfo.ticker, "XAG") ? 100 :
      str.contains(syminfo.ticker, "JPY") ? 10  : 10)

// ─────────────────────────────────────────────────────────────────────
// TIERED RISK SIZING  (fixed £ amounts, not % of equity)
// ─────────────────────────────────────────────────────────────────────
// Rules:
//   Balance  £50  → £99   : risk £5  per trade
//   Balance  £100 → £199  : risk £10 per trade
//   Balance  £200 → £499  : risk £20 per trade  (hard cap until £500)
//   Balance  £500+         : stays at £20 — manual re-evaluation needed
//
// Lot size = risk_amount / (sl_pips × pip_value_per_lot_in_GBP)
// Pip value per standard lot ≈ £7.87 for major USD pairs at GBPUSD 1.27
// (XAU and JPY pairs use slightly different values — adjust live)
// ─────────────────────────────────────────────────────────────────────
float balance = strategy.equity

// $200-$499 and $500+ → $20 (capped) | $100-$199 → $10 | $50-$99 → $5
float risk_amount = (balance >= 200.0 ? 20.0 :
                     balance >= 100.0 ? 10.0 :
                                         5.0)

// Risk tier label for the info table
string risk_tier = (balance >= 500.0 ? "$20  ⚠ re-evaluate" :
                    balance >= 200.0 ? "$20 / trade" :
                    balance >= 100.0 ? "$10 / trade" :
                                       "$5  / trade")

// Approximate pip value per standard lot in USD
// XAUUSD: $10/pip  |  EURUSD: $10/pip  |  GBPUSD: $10/pip  |  JPY pairs: ~$9/pip
float pip_val_per_lot = (str.contains(syminfo.ticker, "XAU") ? 10.0 :
                         str.contains(syminfo.ticker, "JPY") ?  9.0 : 10.0)

// Calculate lot size, rounded to nearest 0.01, clamped to 0.01–5.0
f_lots(sl_pips) =>
    float raw  = risk_amount / math.max(sl_pips, 1.0) / pip_val_per_lot
    float lots = math.round(raw / 0.01) * 0.01
    math.max(0.01, math.min(5.0, lots))

// ─────────────────────────────────────────────────────────────────────
// CONTRARIAN SENTIMENT CONFIRMATION
// ─────────────────────────────────────────────────────────────────────
// Core ICT principle: institutions move AGAINST retail positioning.
// myfxbook shows where retail traders are piled in — we fade that crowd.
// In this backtest we proxy myfxbook with D1 RSI extremes:
//   RSI ≥ 60  → retail majority LONG  → institutions likely SHORT  → we SHORT
//   RSI ≤ 40  → retail majority SHORT → institutions likely LONG   → we LONG
//
// This is the FIRST filter — if sentiment isn't at an extreme, no trade.
// ─────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────
// KILL ZONE  (M15 chart time)
// ─────────────────────────────────────────────────────────────────────
int  utcH = hour(time, "UTC")
bool inKZ = ((use_london and utcH >= london_start and utcH < london_end) or
              (use_ny     and utcH >= ny_start     and utcH < ny_end))

bgcolor(use_london and utcH >= london_start and utcH < london_end ? color.new(color.blue,   92) : na, title="London KZ")
bgcolor(use_ny     and utcH >= ny_start     and utcH < ny_end     ? color.new(color.orange, 92) : na, title="NY KZ")

// ─────────────────────────────────────────────────────────────────────
// D1 BIAS — driven by myfxbook sentiment (manual in backtest, CSV in live EA)
// ─────────────────────────────────────────────────────────────────────
int d1_bias = (sentiment_bias == "Longs only"  ?  1 :
               sentiment_bias == "Shorts only" ? -1 : 0)

// ─────────────────────────────────────────────────────────────────────
// H4 TREND — must agree with D1 bias (previous completed H4 bar)
// ─────────────────────────────────────────────────────────────────────
float h4_ema_now  = request.security(syminfo.tickerid, "240",
                        ta.ema(close, h4_ema_len)[1],
                        lookahead = barmerge.lookahead_off)
float h4_ema_prev = request.security(syminfo.tickerid, "240",
                        ta.ema(close, h4_ema_len)[2],
                        lookahead = barmerge.lookahead_off)
bool h4_bull = h4_ema_now > h4_ema_prev   // H4 trending up
bool h4_bear = h4_ema_now < h4_ema_prev   // H4 trending down

// Final directional bias
// "Both" = d1_bias is 0 so bypass the sentiment check entirely
bool bias_long  = (sentiment_bias == "Both" ? (not require_h4 or h4_bull)  : (d1_bias ==  1 and (not require_h4 or h4_bull)))
bool bias_short = (sentiment_bias == "Both" ? (not require_h4 or h4_bear)  : (d1_bias == -1 and (not require_h4 or h4_bear)))

// ─────────────────────────────────────────────────────────────────────
// D1 ORDER BLOCKS & FVGs
// Higher timeframe OBs carry more weight — price respects them more.
// All data uses [1]/[2] offsets + lookahead_off → confirmed bars only.
// ─────────────────────────────────────────────────────────────────────
float d1_o1 = request.security(syminfo.tickerid, "D", open [1], lookahead=barmerge.lookahead_off)
float d1_h1 = request.security(syminfo.tickerid, "D", high [1], lookahead=barmerge.lookahead_off)
float d1_l1 = request.security(syminfo.tickerid, "D", low  [1], lookahead=barmerge.lookahead_off)
float d1_c1 = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)
float d1_h2 = request.security(syminfo.tickerid, "D", high [2], lookahead=barmerge.lookahead_off)
float d1_l2 = request.security(syminfo.tickerid, "D", low  [2], lookahead=barmerge.lookahead_off)
float d1_o2 = request.security(syminfo.tickerid, "D", open [2], lookahead=barmerge.lookahead_off)
float d1_c2 = request.security(syminfo.tickerid, "D", close[2], lookahead=barmerge.lookahead_off)

// D1 OB: last completed D1 bar is a qualifying OB body
float d1_body1    = math.abs(d1_c1 - d1_o1)
float d1_ob_top   = math.max(d1_o1, d1_c1)
float d1_ob_bot   = math.min(d1_o1, d1_c1)
bool  in_d1_bull_ob = (d1_c1 < d1_o1 and d1_body1/pip >= h1_ob_min_body and
                       close >= d1_ob_bot - 5*pip and close <= d1_ob_top + 5*pip)
bool  in_d1_bear_ob = (d1_c1 > d1_o1 and d1_body1/pip >= h1_ob_min_body and
                       close >= d1_ob_bot - 5*pip and close <= d1_ob_top + 5*pip)

// D1 FVG: 3-bar imbalance using confirmed D1 bars [2] and [1]
float d1_bull_fvg_bot = d1_h2
float d1_bull_fvg_top = d1_l1
bool  in_d1_bull_fvg  = (d1_l1 > d1_h2 and (d1_l1-d1_h2)/pip >= h1_fvg_min and
                         close >= d1_bull_fvg_bot and close <= d1_bull_fvg_top)
float d1_bear_fvg_top = d1_l2
float d1_bear_fvg_bot = d1_h1
bool  in_d1_bear_fvg  = (d1_l2 > d1_h1 and (d1_l2-d1_h1)/pip >= h1_fvg_min and
                         close >= d1_bear_fvg_bot and close <= d1_bear_fvg_top)

// ─────────────────────────────────────────────────────────────────────
// H4 ORDER BLOCKS & FVGs
// ─────────────────────────────────────────────────────────────────────
float h4_o1 = request.security(syminfo.tickerid, "240", open [1], lookahead=barmerge.lookahead_off)
float h4_h1 = request.security(syminfo.tickerid, "240", high [1], lookahead=barmerge.lookahead_off)
float h4_l1 = request.security(syminfo.tickerid, "240", low  [1], lookahead=barmerge.lookahead_off)
float h4_c1 = request.security(syminfo.tickerid, "240", close[1], lookahead=barmerge.lookahead_off)
float h4_h2 = request.security(syminfo.tickerid, "240", high [2], lookahead=barmerge.lookahead_off)
float h4_l2 = request.security(syminfo.tickerid, "240", low  [2], lookahead=barmerge.lookahead_off)
float h4_o2 = request.security(syminfo.tickerid, "240", open [2], lookahead=barmerge.lookahead_off)
float h4_c2 = request.security(syminfo.tickerid, "240", close[2], lookahead=barmerge.lookahead_off)

// H4 OB
float h4_body1    = math.abs(h4_c1 - h4_o1)
float h4_ob_top   = math.max(h4_o1, h4_c1)
float h4_ob_bot   = math.min(h4_o1, h4_c1)
bool  in_h4_bull_ob = (h4_c1 < h4_o1 and h4_body1/pip >= h1_ob_min_body and
                       close >= h4_ob_bot - 3*pip and close <= h4_ob_top + 3*pip)
bool  in_h4_bear_ob = (h4_c1 > h4_o1 and h4_body1/pip >= h1_ob_min_body and
                       close >= h4_ob_bot - 3*pip and close <= h4_ob_top + 3*pip)

// H4 FVG
float h4_bull_fvg_bot = h4_h2
float h4_bull_fvg_top = h4_l1
bool  in_h4_bull_fvg  = (h4_l1 > h4_h2 and (h4_l1-h4_h2)/pip >= h1_fvg_min and
                         close >= h4_bull_fvg_bot and close <= h4_bull_fvg_top)
float h4_bear_fvg_top = h4_l2
float h4_bear_fvg_bot = h4_h1
bool  in_h4_bear_fvg  = (h4_l2 > h4_h1 and (h4_l2-h4_h1)/pip >= h1_fvg_min and
                         close >= h4_bear_fvg_bot and close <= h4_bear_fvg_top)

// ─────────────────────────────────────────────────────────────────────
// H1 ORDER BLOCKS & FVGs
// ─────────────────────────────────────────────────────────────────────
float h1_open  = request.security(syminfo.tickerid, "60", open [1], lookahead=barmerge.lookahead_off)
float h1_high  = request.security(syminfo.tickerid, "60", high [1], lookahead=barmerge.lookahead_off)
float h1_low   = request.security(syminfo.tickerid, "60", low  [1], lookahead=barmerge.lookahead_off)
float h1_close = request.security(syminfo.tickerid, "60", close[1], lookahead=barmerge.lookahead_off)

float h1_body    = math.abs(h1_close - h1_open)
float h1_ob_top  = math.max(h1_open, h1_close)
float h1_ob_bot  = math.min(h1_open, h1_close)
bool  in_h1_bull_ob = (h1_close < h1_open and h1_body/pip >= h1_ob_min_body and
                       close >= h1_ob_bot - 3*pip and close <= h1_ob_top + 3*pip)
bool  in_h1_bear_ob = (h1_close > h1_open and h1_body/pip >= h1_ob_min_body and
                       close >= h1_ob_bot - 3*pip and close <= h1_ob_top + 3*pip)

float h1_p2_high = request.security(syminfo.tickerid, "60", high[2], lookahead=barmerge.lookahead_off)
float h1_p2_low  = request.security(syminfo.tickerid, "60", low [2], lookahead=barmerge.lookahead_off)
float h1_p0_high = request.security(syminfo.tickerid, "60", high[1], lookahead=barmerge.lookahead_off)
float h1_p0_low  = request.security(syminfo.tickerid, "60", low [1], lookahead=barmerge.lookahead_off)

float h1_bull_fvg_bot = h1_p2_high
float h1_bull_fvg_top = h1_p0_low
bool  in_h1_bull_fvg  = (h1_p0_low > h1_p2_high and (h1_p0_low-h1_p2_high)/pip >= h1_fvg_min and
                         close >= h1_bull_fvg_bot and close <= h1_bull_fvg_top)
float h1_bear_fvg_top = h1_p2_low
float h1_bear_fvg_bot = h1_p0_high
bool  in_h1_bear_fvg  = (h1_p2_low > h1_p0_high and (h1_p2_low-h1_p0_high)/pip >= h1_fvg_min and
                         close >= h1_bear_fvg_bot and close <= h1_bear_fvg_top)

// ─────────────────────────────────────────────────────────────────────
// M15 LIQUIDITY LEVELS & SWEEP DETECTION
// ─────────────────────────────────────────────────────────────────────
float ph = ta.pivothigh(high, m15_pivot_len, m15_pivot_len)
float pl = ta.pivotlow (low,  m15_pivot_len, m15_pivot_len)

var float bsl_level = na
var float ssl_level = na

if not na(ph)
    bsl_level := ph
if not na(pl)
    ssl_level := pl

// Check sweep across the last sweep_window M15 bars (not just 1)
// A sweep = wick past the level, close back on the other side
bool bsl_swept = false
bool ssl_swept = false

if not na(bsl_level)
    for k = 1 to sweep_window
        if high[k] > bsl_level and close[k] < bsl_level
            bsl_swept := true
            break

if not na(ssl_level)
    for k = 1 to sweep_window
        if low[k] < ssl_level and close[k] > ssl_level
            ssl_swept := true
            break

// Visual sweep markers
plotshape(bsl_swept, "BSL Swept", shape.triangledown, location.abovebar,
          color.new(color.red,   0), size=size.small, offset=-1)
plotshape(ssl_swept, "SSL Swept", shape.triangleup,   location.belowbar,
          color.new(color.green, 0), size=size.small, offset=-1)

// ─────────────────────────────────────────────────────────────────────
// MARKET STRUCTURE SHIFT  (BOS / CHoCH on M15)
// ─────────────────────────────────────────────────────────────────────
// After a liquidity sweep, we require a Break of Structure / Change of
// Character (CHoCH) to confirm the institutional reversal before entering.
//
// ICT sequence:
//   1. Kill zone        — timing filter
//   2. Liquidity sweep  — stop hunt clears out retail orders
//   3. BOS / CHoCH      — price breaks through internal structure →
//                         confirms institutions have reversed direction
//   4. OB / FVG retrace — precision entry inside the zone
//
// Implementation:
//   SSL swept → bullish CHoCH = close > recent internal swing HIGH
//   BSL swept → bearish CHoCH = close < recent internal swing LOW
//
// We use a 2-bar internal pivot (tighter than the BSL/SSL pivot) to
// detect the first structure break immediately after the sweep.
// ─────────────────────────────────────────────────────────────────────
float ms_ph = ta.pivothigh(high, 2, 2)   // 2-bar internal swing high
float ms_pl = ta.pivotlow (low,  2, 2)   // 2-bar internal swing low

var float ms_high = na   // last confirmed internal swing high
var float ms_low  = na   // last confirmed internal swing low

if not na(ms_ph)
    ms_high := ms_ph
if not na(ms_pl)
    ms_low  := ms_pl

// BOS / CHoCH — close breaks through structural level after a sweep
bool bos_bull = ssl_swept and not na(ms_high) and close > ms_high
bool bos_bear = bsl_swept and not na(ms_low)  and close < ms_low

// Visual BOS markers
plotshape(bos_bull, "BOS Bull", shape.labelup,   location.belowbar,
          color.new(color.teal,  20), size=size.tiny, text="BOS")
plotshape(bos_bear, "BOS Bear", shape.labeldown, location.abovebar,
          color.new(color.maroon,20), size=size.tiny, text="BOS")

// ─────────────────────────────────────────────────────────────────────
// M15 ORDER BLOCKS (backup — used if no H1 OB/FVG in range)
// ─────────────────────────────────────────────────────────────────────
bool  m15_bullOB = false
bool  m15_bearOB = false
float m15_bullOB_top = na
float m15_bullOB_bot = na
float m15_bearOB_top = na
float m15_bearOB_bot = na

if bar_index > h1_ob_lookback + 5
    for i = 2 to h1_ob_lookback
        float o_i  = open[i]
        float c_i  = close[i]
        float h_i  = high[i]
        float l_i  = low[i]
        float body = math.abs(c_i - o_i) / pip
        if body >= h1_ob_min_body
            if c_i < o_i and not m15_bullOB
                bool up_imp = false
                for j = 1 to math.min(i-1, 5)
                    if high[i-j] > h_i
                        up_imp := true
                        break
                if up_imp and close >= c_i - 3*pip and close <= o_i + 3*pip
                    m15_bullOB     := true
                    m15_bullOB_top := o_i
                    m15_bullOB_bot := c_i
            if c_i > o_i and not m15_bearOB
                bool dn_imp = false
                for j = 1 to math.min(i-1, 5)
                    if low[i-j] < l_i
                        dn_imp := true
                        break
                if dn_imp and close >= o_i - 3*pip and close <= c_i + 3*pip
                    m15_bearOB     := true
                    m15_bearOB_top := c_i
                    m15_bearOB_bot := o_i

// ─────────────────────────────────────────────────────────────────────
// M15 FAIR VALUE GAPS (backup)
// ─────────────────────────────────────────────────────────────────────
bool  m15_bullFVG = false
bool  m15_bearFVG = false
float m15_bullFVG_top = na
float m15_bullFVG_bot = na
float m15_bearFVG_top = na
float m15_bearFVG_bot = na

if bar_index > h1_fvg_lookback + 5
    for i = 2 to h1_fvg_lookback
        float pH = high[i+1]
        float pL = low[i+1]
        float nH = high[i-1]
        float nL = low[i-1]
        if not m15_bullFVG and nL > pH
            float gap = (nL - pH) / pip
            if gap >= h1_fvg_min and close >= pH and close <= nL
                m15_bullFVG     := true
                m15_bullFVG_top := nL
                m15_bullFVG_bot := pH
        if not m15_bearFVG and nH < pL
            float gap = (pL - nH) / pip
            if gap >= h1_fvg_min and close >= nH and close <= pL
                m15_bearFVG     := true
                m15_bearFVG_top := pL
                m15_bearFVG_bot := nH

// ─────────────────────────────────────────────────────────────────────
// STRUCTURE CONFLUENCE — D1 > H4 > H1 > M15 priority
// ─────────────────────────────────────────────────────────────────────
bool structL = (in_d1_bull_ob or in_d1_bull_fvg or
                in_h4_bull_ob or in_h4_bull_fvg or
                in_h1_bull_ob or in_h1_bull_fvg or
                m15_bullOB    or m15_bullFVG)
bool structS = (in_d1_bear_ob or in_d1_bear_fvg or
                in_h4_bear_ob or in_h4_bear_fvg or
                in_h1_bear_ob or in_h1_bear_fvg or
                m15_bearOB    or m15_bearFVG)

// Best available zone label for entry labels and SL reference
string best_zone_long  = (in_d1_bull_ob ? "D1 OB"  : in_d1_bull_fvg ? "D1 FVG" :
                          in_h4_bull_ob ? "H4 OB"  : in_h4_bull_fvg ? "H4 FVG" :
                          in_h1_bull_ob ? "H1 OB"  : in_h1_bull_fvg ? "H1 FVG" :
                          m15_bullOB    ? "M15 OB" : "M15 FVG")
string best_zone_short = (in_d1_bear_ob ? "D1 OB"  : in_d1_bear_fvg ? "D1 FVG" :
                          in_h4_bear_ob ? "H4 OB"  : in_h4_bear_fvg ? "H4 FVG" :
                          in_h1_bear_ob ? "H1 OB"  : in_h1_bear_fvg ? "H1 FVG" :
                          m15_bearOB    ? "M15 OB" : "M15 FVG")


// ─────────────────────────────────────────────────────────────────────
// WEEKLY TRADE CAP
// ─────────────────────────────────────────────────────────────────────
var int week_trades = 0
var int prev_closed = 0

if dayofweek(time) == 2 and dayofweek(time[1]) != 2
    week_trades := 0

int newly_closed = strategy.closedtrades - prev_closed
if newly_closed > 0
    week_trades := week_trades + newly_closed
prev_closed := strategy.closedtrades

bool under_cap = (strategy.opentrades + week_trades) < max_wk_trades

// ─────────────────────────────────────────────────────────────────────
// PENDING SETUP STATE — BOS confirmed, now wait for retrace into zone
// ─────────────────────────────────────────────────────────────────────
// Correct ICT entry is SEQUENTIAL, not simultaneous:
//   Step 1: BOS/CHoCH fires during kill zone (displacement candle)
//   Step 2: Price RETRACES into D1/H4/H1/M15 OB or FVG zone
//   Step 3: Entry fires at zone, SL below zone edge
//
// Requiring BOS + in-zone simultaneously is contradictory:
//   BOS = close broke above swing high (price moved UP and away)
//   In-zone = price pulled back INTO the zone below
// They cannot occur on the same bar for the same direction.
// ─────────────────────────────────────────────────────────────────────
var bool pending_long  = false
var bool pending_short = false
var int  bos_bar_long  = 0
var int  bos_bar_short = 0

if bos_bull and inKZ and bias_long
    pending_long  := true
    bos_bar_long  := bar_index
if bos_bear and inKZ and bias_short
    pending_short := true
    bos_bar_short := bar_index

// Expire if no retrace found within window
if pending_long  and (bar_index - bos_bar_long)  > bos_expire_bars
    pending_long  := false
if pending_short and (bar_index - bos_bar_short) > bos_expire_bars
    pending_short := false

// Cancel if HTF bias flips strongly (RSI crosses back through 50 — full reversal, not a wobble)
if d1_rsi > 50 and pending_long
    pending_long  := false
if d1_rsi < 50 and pending_short
    pending_short := false

// ─────────────────────────────────────────────────────────────────────
// ENTRY CONDITIONS — sequential ICT flow
// ─────────────────────────────────────────────────────────────────────
//   Phase 1 (sets pending): BOS during kill zone + HTF bias
//   Phase 2 (entry):        pending active + price in any TF zone
//   Trade can enter inside or outside kill zone (BOS must occur in KZ)
// ─────────────────────────────────────────────────────────────────────
bool canTrade = strategy.opentrades < max_pos and under_cap

// Build up entry conditions layer by layer — toggle each filter on/off independently
bool zone_ok_l = (not require_zone) or structL
bool zone_ok_s = (not require_zone) or structS

bool longCond  = canTrade and (require_bos ? (pending_long  and zone_ok_l) : (bias_long  and inKZ and zone_ok_l))
bool shortCond = canTrade and (require_bos ? (pending_short and zone_ok_s) : (bias_short and inKZ and zone_ok_s))

if longCond
    pending_long  := false
if shortCond
    pending_short := false

// ─────────────────────────────────────────────────────────────────────
// SL PLACEMENT — at the trade-invalidation point, not just zone edge
// ─────────────────────────────────────────────────────────────────────
// ICT logic:
//   Long  → SL below the SSL sweep low  (if price returns below the swept
//            low, the bullish thesis is dead — trade invalidated)
//   Short → SL above the BSL sweep high (if price returns above the swept
//            high, the bearish thesis is dead — trade invalidated)
//
// sl_buffer_pips gives breathing room so a 1-pip undercut doesn't stop out.
// Falls back to OB/FVG zone edge, then fixed_sl_pips, if levels are na.
// ─────────────────────────────────────────────────────────────────────
// SL at zone edge (OB/FVG bottom for longs, top for shorts) — zone break = trade invalidated
float sl_stop_long  = in_d1_bull_ob  ? d1_ob_bot        - sl_buffer_pips * pip :
                      in_d1_bull_fvg ? d1_bull_fvg_bot  - sl_buffer_pips * pip :
                      in_h4_bull_ob  ? h4_ob_bot        - sl_buffer_pips * pip :
                      in_h4_bull_fvg ? h4_bull_fvg_bot  - sl_buffer_pips * pip :
                      in_h1_bull_ob  ? h1_ob_bot        - sl_buffer_pips * pip :
                      in_h1_bull_fvg ? h1_bull_fvg_bot  - sl_buffer_pips * pip :
                      m15_bullOB     ? m15_bullOB_bot   - sl_buffer_pips * pip :
                      m15_bullFVG    ? m15_bullFVG_bot  - sl_buffer_pips * pip :
                      not na(ssl_level) ? ssl_level     - sl_buffer_pips * pip :
                                          close         - fixed_sl_pips * pip

float sl_stop_short = in_d1_bear_ob  ? d1_ob_top        + sl_buffer_pips * pip :
                      in_d1_bear_fvg ? d1_bear_fvg_top  + sl_buffer_pips * pip :
                      in_h4_bear_ob  ? h4_ob_top        + sl_buffer_pips * pip :
                      in_h4_bear_fvg ? h4_bear_fvg_top  + sl_buffer_pips * pip :
                      in_h1_bear_ob  ? h1_ob_top        + sl_buffer_pips * pip :
                      in_h1_bear_fvg ? h1_bear_fvg_top  + sl_buffer_pips * pip :
                      m15_bearOB     ? m15_bearOB_top   + sl_buffer_pips * pip :
                      m15_bearFVG    ? m15_bearFVG_top  + sl_buffer_pips * pip :
                      not na(bsl_level) ? bsl_level     + sl_buffer_pips * pip :
                                          close         + fixed_sl_pips * pip

float sl_pips_long  = (close - sl_stop_long)  / pip
float sl_pips_short = (sl_stop_short - close) / pip

// Clamp SL: XAUUSD floor=20 pips ($20), ceiling=200 pips ($200)
// FX majors floor=10 pips, ceiling=60 pips — auto-scales with pip definition
float sl_floor   = str.contains(syminfo.ticker, "XAU") ? 20.0 : 10.0
float sl_ceiling = str.contains(syminfo.ticker, "XAU") ? 200.0 : 60.0
sl_pips_long  := math.max(sl_floor, math.min(sl_ceiling, sl_pips_long))
sl_pips_short := math.max(sl_floor, math.min(sl_ceiling, sl_pips_short))

// Partial close at 2:1,  final close at full_rr (default 3:1)
int sl_ticks_l    = math.round(sl_pips_long  * pip / syminfo.mintick)
int tp2r_ticks_l  = math.round(sl_pips_long  * 2.0 * pip / syminfo.mintick)   // 2:1 partial
int tp3r_ticks_l  = math.round(sl_pips_long  * full_rr * pip / syminfo.mintick) // final

int sl_ticks_s    = math.round(sl_pips_short * pip / syminfo.mintick)
int tp2r_ticks_s  = math.round(sl_pips_short * 2.0 * pip / syminfo.mintick)
int tp3r_ticks_s  = math.round(sl_pips_short * full_rr * pip / syminfo.mintick)

// ─────────────────────────────────────────────────────────────────────
// PLACE ENTRIES + EXITS
// ─────────────────────────────────────────────────────────────────────
if longCond
    strategy.entry("Long", strategy.long, qty=f_lots(sl_pips_long), comment="ICT L")
    if use_partial
        strategy.exit("Long 2R",   "Long", qty_percent=30, profit=tp2r_ticks_l, loss=sl_ticks_l)
        strategy.exit("Long Full", "Long", qty_percent=70, profit=tp3r_ticks_l, loss=sl_ticks_l)
    else
        strategy.exit("Long Exit", "Long", profit=tp3r_ticks_l, loss=sl_ticks_l)

if shortCond
    strategy.entry("Short", strategy.short, qty=f_lots(sl_pips_short), comment="ICT S")
    if use_partial
        strategy.exit("Short 2R",   "Short", qty_percent=30, profit=tp2r_ticks_s, loss=sl_ticks_s)
        strategy.exit("Short Full", "Short", qty_percent=70, profit=tp3r_ticks_s, loss=sl_ticks_s)
    else
        strategy.exit("Short Exit", "Short", profit=tp3r_ticks_s, loss=sl_ticks_s)

// ─────────────────────────────────────────────────────────────────────
// BREAKEVEN at 1:1 — move SL to entry once trade is up 1R
// ─────────────────────────────────────────────────────────────────────
var float entry_long  = na
var float entry_short = na
var bool  be_done_l   = false
var bool  be_done_s   = false

if longCond
    entry_long := close
    be_done_l  := false
if shortCond
    entry_short := close
    be_done_s   := false

if use_be
    if strategy.position_size > 0 and not be_done_l and not na(entry_long)
        if (close - entry_long) / pip >= sl_pips_long    // reached 1:1
            strategy.exit("Long BE", "Long", stop = entry_long + syminfo.mintick)
            be_done_l := true

    if strategy.position_size < 0 and not be_done_s and not na(entry_short)
        if (entry_short - close) / pip >= sl_pips_short  // reached 1:1
            strategy.exit("Short BE", "Short", stop = entry_short - syminfo.mintick)
            be_done_s := true

// ─────────────────────────────────────────────────────────────────────
// WEEKEND EXIT — close before Friday market close to avoid gap risk
// ─────────────────────────────────────────────────────────────────────
// Trades CAN hold through the week — no intraday forced exit.
// The only forced close is Friday at 20:00 UTC (before weekend gap).
// ─────────────────────────────────────────────────────────────────────
bool friday_close = dayofweek(time) == 6 and utcH >= 20

if session_exit and friday_close and strategy.position_size != 0
    strategy.close_all(comment="Weekend Close")

// ─────────────────────────────────────────────────────────────────────
// VISUALS — entry labels + SL/TP lines
// ─────────────────────────────────────────────────────────────────────
int vis_extend = 80   // how many bars the SL/TP lines extend to the right

if longCond
    float e  = close
    float sl = e - sl_pips_long  * pip
    float t1 = e + sl_pips_long  * 2.0 * pip
    float t2 = e + sl_pips_long  * full_rr  * pip
    // entry label
    label.new(bar_index, low - 5*pip,
              "▲ LONG\n" + best_zone_long + "\nSL " + str.tostring(math.round(sl_pips_long,1)) + "p",
              color=color.new(color.teal, 15), textcolor=color.white,
              style=label.style_label_up, size=size.small)
    // SL / TP lines
    line.new(bar_index, sl, bar_index + vis_extend, sl, color=color.red,    width=1, style=line.style_dashed)
    line.new(bar_index, t1, bar_index + vis_extend, t1, color=color.orange, width=1, style=line.style_dashed)
    line.new(bar_index, t2, bar_index + vis_extend, t2, color=color.lime,   width=2, style=line.style_dashed)
    line.new(bar_index, e,  bar_index + vis_extend, e,  color=color.teal,   width=1, style=line.style_dotted)

if shortCond
    float e  = close
    float sl = e + sl_pips_short * pip
    float t1 = e - sl_pips_short * 2.0 * pip
    float t2 = e - sl_pips_short * full_rr  * pip
    // entry label
    label.new(bar_index, high + 5*pip,
              "▼ SHORT\n" + best_zone_short + "\nSL " + str.tostring(math.round(sl_pips_short,1)) + "p",
              color=color.new(color.maroon, 15), textcolor=color.white,
              style=label.style_label_down, size=size.small)
    // SL / TP lines
    line.new(bar_index, sl, bar_index + vis_extend, sl, color=color.red,    width=1, style=line.style_dashed)
    line.new(bar_index, t1, bar_index + vis_extend, t1, color=color.orange, width=1, style=line.style_dashed)
    line.new(bar_index, t2, bar_index + vis_extend, t2, color=color.lime,   width=2, style=line.style_dashed)
    line.new(bar_index, e,  bar_index + vis_extend, e,  color=color.maroon, width=1, style=line.style_dotted)

plot(bsl_level, "BSL", color.new(color.red,   55), 1, plot.style_circles)
plot(ssl_level, "SSL", color.new(color.green, 55), 1, plot.style_circles)

// H1 OB boxes
var box h1_bull_box = na
var box h1_bear_box = na
if in_h1_bull_ob
    h1_bull_box := box.new(bar_index-1, h1_ob_top, bar_index+10, h1_ob_bot,
                           border_color=color.new(color.teal,40),
                           bgcolor=color.new(color.teal,85))
if in_h1_bear_ob
    h1_bear_box := box.new(bar_index-1, h1_ob_top, bar_index+10, h1_ob_bot,
                           border_color=color.new(color.maroon,40),
                           bgcolor=color.new(color.maroon,85))

// ─────────────────────────────────────────────────────────────────────
// INFO TABLE
// ─────────────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────────────
// INFO TABLE  (updated every bar — no barstate.islast needed)
// barstate.islast is unreliable in strategies with calc_on_every_tick=false
// ─────────────────────────────────────────────────────────────────────
var table info = table.new(position.top_right, 2, 12,
     bgcolor=color.new(color.black, 75), border_width=1, frame_width=1)

string sent_label = (sentiment_bias == "Longs only"  ? "Retail SHORT → LONG only" :
                     sentiment_bias == "Shorts only" ? "Retail LONG  → SHORT only" : "Both directions")

string pend_label = (pending_long  ? "LONG pending ▲"  :
                     pending_short ? "SHORT pending ▼" : "none")

table.cell(info, 0, 0,  "ICT Sentinel v5",  text_color=color.white,  text_size=size.small)
table.cell(info, 1, 0,  "D1/H4/H1 zones",  text_color=color.lime,   text_size=size.small)

table.cell(info, 0, 1,  "Sentiment",        text_color=color.yellow, text_size=size.tiny)
table.cell(info, 1, 1,  sent_label,
           text_color=sentiment_bias == "Both" ? color.gray : color.lime, text_size=size.tiny)

table.cell(info, 0, 2,  "H4 Trend",         text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 2,  h4_bull ? "▲ up" : h4_bear ? "▼ down" : "flat",
           text_color=h4_bull ? color.lime : h4_bear ? color.red : color.gray,
           text_size=size.tiny)

table.cell(info, 0, 3,  "Bias",             text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 3,  (bias_long ? "LONG ▲" : bias_short ? "SHORT ▼" : "none"),
           text_color=bias_long ? color.lime : bias_short ? color.red : color.gray,
           text_size=size.tiny)

table.cell(info, 0, 4,  "Kill Zone",        text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 4,  inKZ ? "ACTIVE" : "off",
           text_color=inKZ ? color.orange : color.gray,               text_size=size.tiny)

table.cell(info, 0, 5,  "Sweep L/S",        text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 5,  (ssl_swept ? "SSL✓ " : "SSL✗ ") + (bsl_swept ? "BSL✓" : "BSL✗"),
           text_color=color.white,                                    text_size=size.tiny)

table.cell(info, 0, 6,  "BOS / CHoCH",      text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 6,  (bos_bull ? "Bull✓ " : "Bull✗ ") + (bos_bear ? "Bear✓" : "Bear✗"),
           text_color=bos_bull or bos_bear ? color.lime : color.gray, text_size=size.tiny)

table.cell(info, 0, 7,  "Pending setup",    text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 7,  pend_label,
           text_color=pending_long or pending_short ? color.lime : color.gray,
           text_size=size.tiny)

table.cell(info, 0, 8,  "OB / FVG zone",    text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 8,  (structL ? "L✓ " : "L✗ ") + (structS ? "S✓" : "S✗"),
           text_color=color.white,                                    text_size=size.tiny)

table.cell(info, 0, 9,  "Wk trades",        text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 9,  str.tostring(week_trades) + " / " + str.tostring(max_wk_trades),
           text_color=week_trades >= max_wk_trades ? color.red : color.lime,
           text_size=size.tiny)

table.cell(info, 0, 10, "Risk tier",        text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 10, risk_tier,
           text_color=balance >= 500.0 ? color.orange : color.lime,   text_size=size.tiny)

table.cell(info, 0, 11, "Balance",          text_color=color.gray,   text_size=size.tiny)
table.cell(info, 1, 11, "$" + str.tostring(math.round(balance, 2)),
           text_color=color.white,                                    text_size=size.tiny)
