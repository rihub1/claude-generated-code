// ╔══════════════════════════════════════════════════════════════════╗
// ║    ICT Sentinel — Backtest v3.0  (Pine Script v6)               ║
// ║    Multi-Timeframe: D1/H4 bias  →  H1 structure  →  M15 entry  ║
// ║    Run this script on the M15 chart                              ║
// ╠══════════════════════════════════════════════════════════════════╣
// ║  ANTI-LOOKAHEAD GUARANTEES                                       ║
// ║  1. process_orders_on_close=false → fills at NEXT bar open      ║
// ║  2. calc_on_every_tick=false      → confirmed (closed) bars only ║
// ║  3. All HTF data uses [1] + lookahead_off → previous HTF bar    ║
// ║  4. OB/FVG loops scan backwards from i=2 — all past history     ║
// ║  5. Sweep window: last 5 M15 bars (≈75 mins) — all confirmed    ║
// ╚══════════════════════════════════════════════════════════════════╝

//@version=6
strategy(
     title                   = "ICT Sentinel — Backtest v4.0 (MTF)",
     overlay                 = true,
     process_orders_on_close = false,
     calc_on_every_tick      = false,
     initial_capital         = 50,
     currency                = currency.GBP,
     default_qty_type        = strategy.fixed,    // we calculate lot size manually
     default_qty_value       = 0.01,              // fallback minimum (overridden per trade)
     commission_type         = strategy.commission.percent,
     commission_value        = 0.02,
     slippage                = 2,
     max_bars_back           = 500
     )

// ─────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────

// Kill Zones
bool  use_london    = input.bool (true,  "London Kill Zone",              group="Kill Zones (UTC)")
int   london_start  = input.int  (7,     "London start (UTC)",  minval=0, maxval=23, group="Kill Zones (UTC)")
int   london_end    = input.int  (10,    "London end   (UTC)",  minval=0, maxval=23, group="Kill Zones (UTC)")
bool  use_ny        = input.bool (true,  "New York Kill Zone",            group="Kill Zones (UTC)")
int   ny_start      = input.int  (13,    "NY start (UTC)",      minval=0, maxval=23, group="Kill Zones (UTC)")
int   ny_end        = input.int  (16,    "NY end   (UTC)",      minval=0, maxval=23, group="Kill Zones (UTC)")

// HTF Bias (D1 + H4) — Direction
float d1_sent_long  = input.float(60.0,  "D1 RSI ≥ X  →  SHORT bias (retail majority long)",  minval=51, maxval=90, group="HTF Bias  (D1 + H4)")
float d1_sent_short = input.float(40.0,  "D1 RSI ≤ X  →  LONG  bias (retail majority short)", minval=10, maxval=49, group="HTF Bias  (D1 + H4)")
int   h4_ema_len    = input.int  (20,    "H4 trend EMA length",           minval=5,            group="HTF Bias  (D1 + H4)")
bool  require_h4    = input.bool (true,  "Require H4 trend to agree",                          group="HTF Bias  (D1 + H4)",
                        tooltip="H4 EMA must slope in the same direction as D1 bias.\nIf unchecked, D1 bias alone is enough.")

// H1 Structure (Order Blocks & FVGs identified on H1)
int   h1_ob_lookback = input.int (20,   "H1 OB lookback (bars)",  minval=5, maxval=50,  group="H1 Structure  (OB + FVG)")
float h1_ob_min_body = input.float(5.0, "H1 OB min body (pips)",  minval=1.0,           group="H1 Structure  (OB + FVG)")
int   h1_fvg_lookback= input.int (20,   "H1 FVG lookback (bars)", minval=5, maxval=50,  group="H1 Structure  (OB + FVG)")
float h1_fvg_min     = input.float(3.0, "H1 FVG min size (pips)", minval=0.5,           group="H1 Structure  (OB + FVG)")

// M15 Entry Triggers
int   m15_pivot_len  = input.int (3,    "M15 swing strength (bars each side)", minval=2, maxval=10, group="M15 Entry Triggers")
int   sweep_window   = input.int (5,    "Sweep lookback window (M15 bars)",    minval=1, maxval=10, group="M15 Entry Triggers",
                        tooltip="How many past M15 bars to check for a liquidity sweep.\n5 bars = look back 75 minutes for a sweep.")

// Risk & Exit — tiered fixed-amount sizing
// £50–£99 = £5/trade  |  £100–£199 = £10/trade  |  £200–£499 = £20/trade  |  £500+ = hold at £20
float fixed_sl_pips  = input.float(15.0, "Fallback SL (pips, no OB/FVG)",    minval=5,              group="Risk and Exit")
bool  use_be         = input.bool (true,  "Move SL to breakeven at 1:1",                            group="Risk and Exit")
bool  use_partial    = input.bool (true,  "Close 50% at 2:1 R:R",                                   group="Risk and Exit")
float full_rr        = input.float(3.0,  "Final TP (R:R on remaining 50%)",  minval=2.0,            group="Risk and Exit")
bool  session_exit   = input.bool (true,  "Close at end of kill zone",                              group="Risk and Exit",
                        tooltip="Forces close of any open trade when the kill zone session ends.\nPrevents ICT intraday trades becoming accidental overnight holds.")
int   max_pos        = input.int  (2,    "Max open positions",                minval=1,              group="Risk and Exit")
int   max_wk_trades  = input.int  (6,    "Max trades per week",               minval=1, maxval=20,   group="Risk and Exit")

// ─────────────────────────────────────────────────────────────────────
// PIP SIZE  (auto-detects pair)
// ─────────────────────────────────────────────────────────────────────
float pip = syminfo.mintick *
     (str.contains(syminfo.ticker, "JPY") ? 100 :
      str.contains(syminfo.ticker, "XAU") ? 10  :
      str.contains(syminfo.ticker, "XAG") ? 10  : 10)

// ─────────────────────────────────────────────────────────────────────
// TIERED RISK SIZING  (fixed £ amounts, not % of equity)
// ─────────────────────────────────────────────────────────────────────
// Rules:
//   Balance  £50  → £99   : risk £5  per trade
//   Balance  £100 → £199  : risk £10 per trade
//   Balance  £200 → £499  : risk £20 per trade  (hard cap until £500)
//   Balance  £500+         : stays at £20 — manual re-evaluation needed
//
// Lot size = risk_amount / (sl_pips × pip_value_per_lot_in_GBP)
// Pip value per standard lot ≈ £7.87 for major USD pairs at GBPUSD 1.27
// (XAU and JPY pairs use slightly different values — adjust live)
// ─────────────────────────────────────────────────────────────────────
float balance = strategy.equity

// £200-£499 and £500+ → £20 (capped)  |  £100-£199 → £10  |  £50-£99 → £5
float risk_amount = balance >= 200.0 ? 20.0 : balance >= 100.0 ? 10.0 : 5.0

// Risk tier label for the info table
string risk_tier = balance >= 500.0 ? "£20 re-evaluate" : balance >= 200.0 ? "£20 / trade" : balance >= 100.0 ? "£10 / trade" : "£5 / trade"

// Approximate pip value per standard lot in GBP
// Major pairs vs account currency (GBP): ~£7.87/pip (EURUSD at GBPUSD 1.27)
// GBPUSD: £10/pip  |  GBPJPY: £10/pip  |  XAUUSD: ~£8/pip
float pip_val_per_lot = str.contains(syminfo.ticker, "GBP") ? 10.0 : str.contains(syminfo.ticker, "XAU") ? 8.0 : str.contains(syminfo.ticker, "JPY") ? 7.5 : 7.87

// Calculate lot size, rounded to nearest 0.01, clamped to 0.01–5.0
f_lots(float sl_pips) =>
    float raw  = risk_amount / math.max(sl_pips, 1.0) / pip_val_per_lot
    float lots = math.round(raw / 0.01) * 0.01
    math.max(0.01, math.min(5.0, lots))

// ─────────────────────────────────────────────────────────────────────
// CONTRARIAN SENTIMENT CONFIRMATION
// ─────────────────────────────────────────────────────────────────────
// Core ICT principle: institutions move AGAINST retail positioning.
// myfxbook shows where retail traders are piled in — we fade that crowd.
// In this backtest we proxy myfxbook with D1 RSI extremes:
//   RSI ≥ 60  → retail majority LONG  → institutions likely SHORT  → we SHORT
//   RSI ≤ 40  → retail majority SHORT → institutions likely LONG   → we LONG
//
// This is the FIRST filter — if sentiment isn't at an extreme, no trade.
// ─────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────
// KILL ZONE  (M15 chart time)
// ─────────────────────────────────────────────────────────────────────
int  utcH = hour(time, "UTC")
bool inKZ = (use_london and utcH >= london_start and utcH < london_end) or
             (use_ny     and utcH >= ny_start     and utcH < ny_end)

bgcolor(use_london and utcH >= london_start and utcH < london_end ? color.new(color.blue,   92) : na, title="London KZ")
bgcolor(use_ny     and utcH >= ny_start     and utcH < ny_end     ? color.new(color.orange, 92) : na, title="NY KZ")

// ─────────────────────────────────────────────────────────────────────
// D1 BIAS — sentiment proxy (previous completed daily bar, anti-lookahead)
// ─────────────────────────────────────────────────────────────────────
float d1_rsi = request.security(syminfo.tickerid, "D",
                    ta.rsi(close, 14)[1],
                    lookahead = barmerge.lookahead_off)

// +1 = go LONG (retail majority short, fade them)
// -1 = go SHORT (retail majority long, fade them)
//  0 = no clear extreme, no trade
int d1_bias = d1_rsi <= d1_sent_short ? 1 : d1_rsi >= d1_sent_long ? -1 : 0

// ─────────────────────────────────────────────────────────────────────
// H4 TREND — must agree with D1 bias (previous completed H4 bar)
// ─────────────────────────────────────────────────────────────────────
float h4_ema_now  = request.security(syminfo.tickerid, "240",
                        ta.ema(close, h4_ema_len)[1],
                        lookahead = barmerge.lookahead_off)
float h4_ema_prev = request.security(syminfo.tickerid, "240",
                        ta.ema(close, h4_ema_len)[2],
                        lookahead = barmerge.lookahead_off)
bool h4_bull = h4_ema_now > h4_ema_prev   // H4 trending up
bool h4_bear = h4_ema_now < h4_ema_prev   // H4 trending down

// Final directional bias — D1 required, H4 optional confirmation
bool bias_long  = d1_bias ==  1 and (not require_h4 or h4_bull)
bool bias_short = d1_bias == -1 and (not require_h4 or h4_bear)

// ─────────────────────────────────────────────────────────────────────
// H1 ORDER BLOCKS — identified on H1, entered on M15 retrace
// Uses request.security to fetch H1 OHLCV (confirmed H1 bars only)
// ─────────────────────────────────────────────────────────────────────
float h1_open  = request.security(syminfo.tickerid, "60", open [1], lookahead=barmerge.lookahead_off)
float h1_high  = request.security(syminfo.tickerid, "60", high [1], lookahead=barmerge.lookahead_off)
float h1_low   = request.security(syminfo.tickerid, "60", low  [1], lookahead=barmerge.lookahead_off)
float h1_close = request.security(syminfo.tickerid, "60", close[1], lookahead=barmerge.lookahead_off)

// Simple H1 OB check: is the most recent completed H1 bar itself an OB
// that price has since moved away from and is now retracing into?
float h1_body    = math.abs(h1_close - h1_open)
bool  h1_bear_ob = h1_close < h1_open and h1_body / pip >= h1_ob_min_body  // bearish H1 candle
bool  h1_bull_ob = h1_close > h1_open and h1_body / pip >= h1_ob_min_body  // bullish H1 candle

// Is current M15 price inside the H1 OB zone?
float h1_ob_top  = math.max(h1_open, h1_close)
float h1_ob_bot  = math.min(h1_open, h1_close)
bool  in_h1_bull_ob = h1_bear_ob and close >= h1_ob_bot - 3*pip and close <= h1_ob_top + 3*pip
bool  in_h1_bear_ob = h1_bull_ob and close >= h1_ob_bot - 3*pip and close <= h1_ob_top + 3*pip

// ─────────────────────────────────────────────────────────────────────
// H1 FAIR VALUE GAPS — fetched as arrays via request.security
// ─────────────────────────────────────────────────────────────────────
// Detect on H1 using 3-bar pattern (all past H1 bars, anti-lookahead)
float h1_p2_high = request.security(syminfo.tickerid, "60", high[2], lookahead=barmerge.lookahead_off)
float h1_p2_low  = request.security(syminfo.tickerid, "60", low [2], lookahead=barmerge.lookahead_off)
float h1_p0_high = request.security(syminfo.tickerid, "60", high[1], lookahead=barmerge.lookahead_off)
float h1_p0_low  = request.security(syminfo.tickerid, "60", low [1], lookahead=barmerge.lookahead_off)

// Bullish H1 FVG: gap_bot=h1_p2_high, gap_top=h1_p0_low, price fills from below
float h1_bull_fvg_bot = h1_p2_high
float h1_bull_fvg_top = h1_p0_low
bool  h1_bull_fvg_valid = h1_p0_low > h1_p2_high and (h1_p0_low - h1_p2_high) / pip >= h1_fvg_min
bool  in_h1_bull_fvg    = h1_bull_fvg_valid and close >= h1_bull_fvg_bot and close <= h1_bull_fvg_top

// Bearish H1 FVG: gap_top=h1_p2_low, gap_bot=h1_p0_high
float h1_bear_fvg_top = h1_p2_low
float h1_bear_fvg_bot = h1_p0_high
bool  h1_bear_fvg_valid = h1_p2_low > h1_p0_high and (h1_p2_low - h1_p0_high) / pip >= h1_fvg_min
bool  in_h1_bear_fvg    = h1_bear_fvg_valid and close >= h1_bear_fvg_bot and close <= h1_bear_fvg_top

// ─────────────────────────────────────────────────────────────────────
// M15 LIQUIDITY LEVELS & SWEEP DETECTION
// ─────────────────────────────────────────────────────────────────────
float ph = ta.pivothigh(high, m15_pivot_len, m15_pivot_len)
float pl = ta.pivotlow (low,  m15_pivot_len, m15_pivot_len)

var float bsl_level = na
var float ssl_level = na

if not na(ph)
    bsl_level := ph
if not na(pl)
    ssl_level := pl

// Check sweep across the last sweep_window M15 bars (not just 1)
// A sweep = wick past the level, close back on the other side
bool bsl_swept = false
bool ssl_swept = false

if not na(bsl_level)
    for k = 1 to sweep_window
        if high[k] > bsl_level and close[k] < bsl_level
            bsl_swept := true
            break

if not na(ssl_level)
    for k = 1 to sweep_window
        if low[k] < ssl_level and close[k] > ssl_level
            ssl_swept := true
            break

// Visual sweep markers
plotshape(bsl_swept, "BSL Swept", shape.triangledown, location.abovebar,
          color.new(color.red,   0), size=size.small, offset=-1)
plotshape(ssl_swept, "SSL Swept", shape.triangleup,   location.belowbar,
          color.new(color.green, 0), size=size.small, offset=-1)

// ─────────────────────────────────────────────────────────────────────
// M15 ORDER BLOCKS (backup — used if no H1 OB/FVG in range)
// ─────────────────────────────────────────────────────────────────────
bool  m15_bullOB = false
bool  m15_bearOB = false
float m15_bullOB_top = na
float m15_bullOB_bot = na
float m15_bearOB_top = na
float m15_bearOB_bot = na

if bar_index > h1_ob_lookback + 5
    for i = 2 to h1_ob_lookback
        float o_i  = open[i]
        float c_i  = close[i]
        float h_i  = high[i]
        float l_i  = low[i]
        float body = math.abs(c_i - o_i) / pip
        if body >= h1_ob_min_body
            if c_i < o_i and not m15_bullOB
                bool up_imp = false
                for j = 1 to math.min(i-1, 5)
                    if high[i-j] > h_i
                        up_imp := true
                        break
                if up_imp and close >= c_i - 3*pip and close <= o_i + 3*pip
                    m15_bullOB     := true
                    m15_bullOB_top := o_i
                    m15_bullOB_bot := c_i
            if c_i > o_i and not m15_bearOB
                bool dn_imp = false
                for j = 1 to math.min(i-1, 5)
                    if low[i-j] < l_i
                        dn_imp := true
                        break
                if dn_imp and close >= o_i - 3*pip and close <= c_i + 3*pip
                    m15_bearOB     := true
                    m15_bearOB_top := c_i
                    m15_bearOB_bot := o_i

// ─────────────────────────────────────────────────────────────────────
// M15 FAIR VALUE GAPS (backup)
// ─────────────────────────────────────────────────────────────────────
bool  m15_bullFVG = false
bool  m15_bearFVG = false
float m15_bullFVG_top = na
float m15_bullFVG_bot = na
float m15_bearFVG_top = na
float m15_bearFVG_bot = na

if bar_index > h1_fvg_lookback + 5
    for i = 2 to h1_fvg_lookback
        float pH = high[i+1]
        float pL = low[i+1]
        float nH = high[i-1]
        float nL = low[i-1]
        if not m15_bullFVG and nL > pH
            float gap = (nL - pH) / pip
            if gap >= h1_fvg_min and close >= pH and close <= nL
                m15_bullFVG     := true
                m15_bullFVG_top := nL
                m15_bullFVG_bot := pH
        if not m15_bearFVG and nH < pL
            float gap = (pL - nH) / pip
            if gap >= h1_fvg_min and close >= nH and close <= pL
                m15_bearFVG     := true
                m15_bearFVG_top := pL
                m15_bearFVG_bot := nH

// ─────────────────────────────────────────────────────────────────────
// STRUCTURE CONFLUENCE
// H1 zone takes priority; M15 zone is backup
// ─────────────────────────────────────────────────────────────────────
bool structL = in_h1_bull_ob or in_h1_bull_fvg or m15_bullOB or m15_bullFVG
bool structS = in_h1_bear_ob or in_h1_bear_fvg or m15_bearOB or m15_bearFVG

// SL reference price: use H1 zone bottom/top if available, else M15, else fixed
float sl_ref_long  = in_h1_bull_ob ? h1_ob_bot : in_h1_bull_fvg ? h1_bull_fvg_bot : m15_bullOB ? m15_bullOB_bot : m15_bullFVG ? m15_bullFVG_bot : close - fixed_sl_pips * pip
float sl_ref_short = in_h1_bear_ob ? h1_ob_top : in_h1_bear_fvg ? h1_bear_fvg_top : m15_bearOB ? m15_bearOB_top : m15_bearFVG ? m15_bearFVG_top : close + fixed_sl_pips * pip

// ─────────────────────────────────────────────────────────────────────
// WEEKLY TRADE CAP
// ─────────────────────────────────────────────────────────────────────
var int week_trades = 0
var int prev_closed = 0

if dayofweek(time) == 2 and dayofweek(time[1]) != 2
    week_trades := 0

int newly_closed = strategy.closedtrades - prev_closed
if newly_closed > 0
    week_trades := week_trades + newly_closed
prev_closed := strategy.closedtrades

bool under_cap = (strategy.opentrades + week_trades) < max_wk_trades

// ─────────────────────────────────────────────────────────────────────
// ENTRY CONDITIONS
// ─────────────────────────────────────────────────────────────────────
// NOT all conditions need to align — just the logical groups:
//   1. HTF bias (D1 sentiment + optional H4 trend)  ← direction
//   2. Kill zone active                              ← timing
//   3. M15 liquidity sweep (within sweep_window)    ← trigger
//   4. At least one H1 or M15 structure zone        ← precision entry
// ─────────────────────────────────────────────────────────────────────
bool canTrade = strategy.opentrades < max_pos and under_cap

bool longCond  = canTrade and bias_long  and inKZ and ssl_swept and structL
bool shortCond = canTrade and bias_short and inKZ and bsl_swept and structS

// ─────────────────────────────────────────────────────────────────────
// SL / TP IN PIPS
// ─────────────────────────────────────────────────────────────────────
float sl_pips_long  = (close - sl_ref_long)  / pip + 3   // 3 pip buffer below zone
float sl_pips_short = (sl_ref_short - close) / pip + 3

// Clamp to sensible range
sl_pips_long  := math.max(5, math.min(80, sl_pips_long))
sl_pips_short := math.max(5, math.min(80, sl_pips_short))

// Partial close at 2:1,  final close at full_rr (default 3:1)
int sl_ticks_l    = math.round(sl_pips_long  * pip / syminfo.mintick)
int tp2r_ticks_l  = math.round(sl_pips_long  * 2.0 * pip / syminfo.mintick)   // 2:1 partial
int tp3r_ticks_l  = math.round(sl_pips_long  * full_rr * pip / syminfo.mintick) // final

int sl_ticks_s    = math.round(sl_pips_short * pip / syminfo.mintick)
int tp2r_ticks_s  = math.round(sl_pips_short * 2.0 * pip / syminfo.mintick)
int tp3r_ticks_s  = math.round(sl_pips_short * full_rr * pip / syminfo.mintick)

// ─────────────────────────────────────────────────────────────────────
// PLACE ENTRIES + EXITS
// ─────────────────────────────────────────────────────────────────────
if longCond
    strategy.entry("Long", strategy.long, qty=f_lots(sl_pips_long), comment="ICT L")
    if use_partial
        strategy.exit("Long 2R",   "Long", qty_percent=50, profit=tp2r_ticks_l, loss=sl_ticks_l)
        strategy.exit("Long Full", "Long", qty_percent=50, profit=tp3r_ticks_l, loss=sl_ticks_l)
    else
        strategy.exit("Long Exit", "Long", profit=tp3r_ticks_l, loss=sl_ticks_l)

if shortCond
    strategy.entry("Short", strategy.short, qty=f_lots(sl_pips_short), comment="ICT S")
    if use_partial
        strategy.exit("Short 2R",   "Short", qty_percent=50, profit=tp2r_ticks_s, loss=sl_ticks_s)
        strategy.exit("Short Full", "Short", qty_percent=50, profit=tp3r_ticks_s, loss=sl_ticks_s)
    else
        strategy.exit("Short Exit", "Short", profit=tp3r_ticks_s, loss=sl_ticks_s)

// ─────────────────────────────────────────────────────────────────────
// BREAKEVEN at 1:1 — move SL to entry once trade is up 1R
// ─────────────────────────────────────────────────────────────────────
var float entry_long  = na
var float entry_short = na
var bool  be_done_l   = false
var bool  be_done_s   = false

if longCond
    entry_long := close
    be_done_l  := false
if shortCond
    entry_short := close
    be_done_s   := false

if use_be
    if strategy.position_size > 0 and not be_done_l and not na(entry_long)
        if (close - entry_long) / pip >= sl_pips_long    // reached 1:1
            strategy.exit("Long BE", "Long", stop = entry_long + syminfo.mintick)
            be_done_l := true

    if strategy.position_size < 0 and not be_done_s and not na(entry_short)
        if (entry_short - close) / pip >= sl_pips_short  // reached 1:1
            strategy.exit("Short BE", "Short", stop = entry_short - syminfo.mintick)
            be_done_s := true

// ─────────────────────────────────────────────────────────────────────
// SESSION EXIT — force close when kill zone ends (ICT intraday rule)
// ─────────────────────────────────────────────────────────────────────
bool london_just_ended = use_london and utcH == london_end and hour(time[1], "UTC") == london_end - 1
bool ny_just_ended     = use_ny     and utcH == ny_end     and hour(time[1], "UTC") == ny_end     - 1

if session_exit and (london_just_ended or ny_just_ended) and strategy.position_size != 0
    strategy.close_all(comment="Session End")

// ─────────────────────────────────────────────────────────────────────
// VISUALS — entry labels
// ─────────────────────────────────────────────────────────────────────
string long_zone  = in_h1_bull_ob ? "H1 OB" : in_h1_bull_fvg ? "H1 FVG" : m15_bullOB ? "M15 OB" : "M15 FVG"
string short_zone = in_h1_bear_ob ? "H1 OB" : in_h1_bear_fvg ? "H1 FVG" : m15_bearOB ? "M15 OB" : "M15 FVG"

if longCond
    label.new(bar_index, low - 5*pip,
              "LONG\n" + long_zone + "\nSL " + str.tostring(math.round(sl_pips_long,1)) + "p",
              color=color.new(color.teal, 15), textcolor=color.white,
              style=label.style_label_up, size=size.small)

if shortCond
    label.new(bar_index, high + 5*pip,
              "SHORT\n" + short_zone + "\nSL " + str.tostring(math.round(sl_pips_short,1)) + "p",
              color=color.new(color.maroon, 15), textcolor=color.white,
              style=label.style_label_down, size=size.small)

plot(bsl_level, "BSL", color.new(color.red,   55), 1, plot.style_circles)
plot(ssl_level, "SSL", color.new(color.green, 55), 1, plot.style_circles)

// H1 OB boxes
var box h1_bull_box = na
var box h1_bear_box = na
if in_h1_bull_ob
    h1_bull_box := box.new(bar_index-1, h1_ob_top, bar_index+10, h1_ob_bot,
                           border_color=color.new(color.teal,40),
                           bgcolor=color.new(color.teal,85))
if in_h1_bear_ob
    h1_bear_box := box.new(bar_index-1, h1_ob_top, bar_index+10, h1_ob_bot,
                           border_color=color.new(color.maroon,40),
                           bgcolor=color.new(color.maroon,85))

// ─────────────────────────────────────────────────────────────────────
// INFO TABLE
// ─────────────────────────────────────────────────────────────────────
var table info = table.new(position.top_right, 2, 10,
     bgcolor=color.new(color.black, 75), border_width=1, frame_width=1)

if barstate.islast
    table.cell(info, 0, 0, "ICT Sentinel v4",   text_color=color.white,  text_size=size.small)
    table.cell(info, 1, 0, "MTF  M15 entry",    text_color=color.lime,   text_size=size.small)

    // ── ROW 1: Contrarian sentiment — FIRST FILTER ──────────────────────
    // RSI proxies myfxbook retail crowd positioning.
    // We trade AGAINST the retail majority — the same way institutions do.
    string sent_label = d1_bias == 1 ? "Retail SHORT -> we LONG" : d1_bias == -1 ? "Retail LONG -> we SHORT" : "No extreme - skip"
    table.cell(info, 0, 1, "1 Sentiment",        text_color=color.yellow, text_size=size.tiny)
    table.cell(info, 1, 1, sent_label,
               text_color=d1_bias != 0 ? color.lime : color.gray,        text_size=size.tiny)

    table.cell(info, 0, 2, "D1 RSI",            text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 2, str.tostring(math.round(d1_rsi,1)),
               text_color=color.white,                                   text_size=size.tiny)

    table.cell(info, 0, 3, "H4 Trend",          text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 3, h4_bull ? "▲ up" : h4_bear ? "▼ down" : "flat",
               text_color=h4_bull ? color.lime : h4_bear ? color.red : color.gray,
               text_size=size.tiny)

    table.cell(info, 0, 4, "Kill Zone",         text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 4, inKZ ? "ACTIVE" : "off",
               text_color=inKZ ? color.orange : color.gray,              text_size=size.tiny)

    table.cell(info, 0, 5, "Sweep L/S",         text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 5, (ssl_swept?"SSL✓ ":"SSL✗ ") + (bsl_swept?"BSL✓":"BSL✗"),
               text_color=color.white,                                   text_size=size.tiny)

    table.cell(info, 0, 6, "Structure",         text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 6, (structL?"L✓ ":"L✗ ") + (structS?"S✓":"S✗"),
               text_color=color.white,                                   text_size=size.tiny)

    table.cell(info, 0, 7, "Wk trades",         text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 7, str.tostring(week_trades) + " / " + str.tostring(max_wk_trades),
               text_color=week_trades>=max_wk_trades ? color.red : color.lime,
               text_size=size.tiny)

    // ── ROW 8: Risk tier ─────────────────────────────────────────────────
    table.cell(info, 0, 8, "Risk tier",          text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 8, risk_tier,
               text_color=balance >= 500.0 ? color.orange : color.lime,  text_size=size.tiny)

    // ── ROW 9: Balance ───────────────────────────────────────────────────
    table.cell(info, 0, 9, "Balance",            text_color=color.gray,   text_size=size.tiny)
    table.cell(info, 1, 9, "£" + str.tostring(math.round(balance, 2)),
               text_color=color.white,                                   text_size=size.tiny)
